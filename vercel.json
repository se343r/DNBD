{
  "version": 2,
  "buildCommand": "npm run build --workspace=frontend && cp -r frontend/dist ./dist",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
